{
  "name": "earshot",
  "private": true,
  "version": "0.0.0",
  "description": "Observability for voice AI agents. Bring your own stack.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:python": ".venv/bin/python -m pytest",
    "test:all": "pnpm test && pnpm test:python",
    "lint:python": ".venv/bin/ruff check packages/sdk-python/src packages/sdk-python/tests apps/ingest scripts examples",
    "generate:contract": ".venv/bin/python scripts/generate_contract.py",
    "serve": ".venv/bin/earshot serve --data-dir .earshot",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,md,json,yaml}\""
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
