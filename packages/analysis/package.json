{
  "name": "@earshot/analysis",
  "version": "0.0.0",
  "private": true,
  "description": "Derives per-call waterfalls, latency metrics, and failure summaries from a trace bundle.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@earshot/schema": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.2.6"
  }
}
